# niche-sites 共通環境変数
#
# 各サブサイト（loan-calc/, salary-calc/, ...）から envDir: '../' で参照される。
# このファイルは .env.example（コミット対象）。実値は同階層に .env を作って
# 記入する（.gitignore で除外済み）。
#
# PUBLIC_ プレフィックスはクライアント側に公開される値（Vite/Astro 慣習）。
# サーバ専用にしたい変数は PUBLIC_ を付けずに書く（現状は無し）。

# ===== 全サイト共通 =====

# サイト運営者名（= ブランド名）。各サイトの「運営者情報」「お問い合わせ」
# やフッターのコピーライト等で使用。
# 例: PUBLIC_OWNER_NAME=やおツールズ
PUBLIC_OWNER_NAME=

# 共通のGoogleフォームURL。1フォームで全サイトの問い合わせを受ける想定
# （フォーム冒頭で「どのサイトからの問い合わせか」を選ぶ運用）
PUBLIC_CONTACT_FORM_URL=

# ===== サイト別（prefix で識別）=====
# サイトごとに別の GA4 プロパティを使う場合、prefix を付けてここに集約。
# 新サイト追加時は PUBLIC_<SITE_NAME>_GA_ID= を追記する。

PUBLIC_PORTAL_GA_ID=
PUBLIC_LOAN_CALC_GA_ID=
# PUBLIC_SALARY_CALC_GA_ID=
# PUBLIC_BMI_CALC_GA_ID=
