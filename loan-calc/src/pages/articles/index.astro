---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const fmt = (d: Date) =>
  `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
---

<BaseLayout
  title="解説記事 | ローン計算ツール集"
  description="ローンの基礎知識、金利の仕組み、返済方式の違いなど、住宅ローンやマイカーローンを理解するための解説記事をまとめたページです。"
  breadcrumb={[
    { name: "トップ", url: "/" },
    { name: "解説記事" },
  ]}
>
  <section class="space-y-2">
    <h1 class="text-3xl font-bold tracking-tight">解説記事</h1>
    <p class="text-slate-600">
      ローンを理解するための基礎知識や、計算結果を読み解くポイントを解説しています。
    </p>
  </section>

  {articles.length === 0 ? (
    <p class="mt-8 text-slate-500">公開中の記事はまだありません。</p>
  ) : (
    <ul class="mt-8 space-y-4">
      {articles.map((article) => (
        <li>
          <a
            href={`/articles/${article.id}/`}
            class="block rounded-xl border border-slate-200 bg-white p-5 transition hover:border-slate-400 hover:shadow-sm"
          >
            <h2 class="text-lg font-bold text-slate-900">{article.data.title}</h2>
            <p class="mt-2 text-sm text-slate-600">{article.data.description}</p>
            <p class="mt-3 text-xs text-slate-500">
              公開: {fmt(article.data.publishedAt)}
            </p>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
