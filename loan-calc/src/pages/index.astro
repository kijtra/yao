---
import BaseLayout from "../layouts/BaseLayout.astro";

const tools = [
  {
    href: "/home/",
    title: "住宅ローン計算機",
    desc: "借入額・返済年数・金利を選んで、月々返済額と総返済額をシミュレーション。",
    ready: true,
  },
  {
    href: "/car/",
    title: "マイカーローン計算機",
    desc: "借入額・返済年数・金利を選んで、月々返済額と総返済額をシミュレーション。",
    ready: true,
  },
  {
    href: "#",
    title: "カードローン計算機",
    desc: "準備中",
    ready: false,
  },
];
---

<BaseLayout
  title="ローン計算ツール集"
  description="住宅ローン・マイカーローン・カードローンなど、各種ローンの返済シミュレーションを行えるツール集。"
>
  <section class="space-y-3">
    <h1 class="text-4xl font-bold tracking-tight">ローン計算ツール集</h1>
    <p class="text-lg text-slate-600">
      住宅ローン・マイカーローン・カードローンの返済額を、借入条件を選ぶだけでシミュレーションできます。
    </p>
  </section>

  <section class="mt-10">
    <h2 class="mb-4 text-xl font-bold">利用可能なツール</h2>
    <ul class="grid gap-4 sm:grid-cols-2">
      {
        tools.map((tool) => (
          <li>
            {tool.ready ? (
              <a
                href={tool.href}
                class="block h-full rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-slate-400 hover:shadow"
              >
                <h3 class="text-lg font-bold text-slate-900">{tool.title}</h3>
                <p class="mt-1 text-sm text-slate-600">{tool.desc}</p>
              </a>
            ) : (
              <div class="block h-full cursor-not-allowed rounded-xl border border-dashed border-slate-200 bg-white/50 p-5 opacity-60">
                <h3 class="text-lg font-bold text-slate-500">{tool.title}</h3>
                <p class="mt-1 text-sm text-slate-400">{tool.desc}</p>
              </div>
            )}
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mt-12">
    <h2 class="mb-4 text-xl font-bold">解説記事を読む</h2>
    <p class="text-slate-600">
      ローンの金利・返済方式・期間設定の考え方など、計算結果を読み解くための基礎知識を解説しています。
    </p>
    <a
      href="/articles/"
      class="mt-4 inline-block rounded-md border border-slate-300 bg-white px-5 py-3 text-sm font-medium text-slate-700 hover:border-slate-500 hover:shadow-sm"
    >
      解説記事の一覧を見る →
    </a>
  </section>
</BaseLayout>
