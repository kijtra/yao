---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  ogImage?: string;
}

const { title, description, publishedAt, updatedAt, ogImage } = Astro.props;

const fmt = (d: Date) =>
  `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
---

<BaseLayout
  title={`${title} | ローン計算ツール集`}
  description={description}
  ogType="article"
  ogImage={ogImage}
  breadcrumb={[
    { name: "トップ", url: "/" },
    { name: "解説記事", url: "/articles/" },
    { name: title },
  ]}
>
  <nav aria-label="パンくず" class="text-sm text-slate-600">
    <a href="/" class="hover:underline">トップ</a>
    <span class="mx-1">/</span>
    <a href="/articles/" class="hover:underline">解説記事</a>
    <span class="mx-1">/</span>
    <span class="text-slate-400">{title}</span>
  </nav>

  <header class="mt-4 border-b border-slate-200 pb-6">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">{title}</h1>
    <p class="mt-3 text-slate-600">{description}</p>
    <div class="mt-4 flex flex-wrap gap-x-4 text-xs text-slate-500">
      <span>公開: {fmt(publishedAt)}</span>
      {updatedAt && <span>更新: {fmt(updatedAt)}</span>}
    </div>
  </header>

  <article class="article-prose mt-8">
    <slot />
  </article>

  <section class="mt-12 border-t border-slate-200 pt-6">
    <a
      href="/articles/"
      class="inline-block rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:border-slate-500"
    >
      ← 解説記事の一覧へ戻る
    </a>
  </section>
</BaseLayout>
